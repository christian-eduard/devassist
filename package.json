{
  "name": "devassist",
  "version": "1.0.0",
  "description": "DevAssist — Asistente personal de desarrollo para Mac",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"PORT=3123 BROWSER=none react-scripts start\" \"wait-on http://localhost:3123 && NODE_ENV=development ELECTRON_RUN_AS_NODE= electron .\"",
    "react-build": "react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "test:unit": "jest tests/fichas-pipeline.test.js --testEnvironment=node --forceExit",
    "test:db": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron tests/run-db-tests.js",
    "test:all": "npm run test:unit && npm run test:db",
    "build": "npm run react-build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.4",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.8.0",
    "chokidar": "^3.5.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.577.0",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^4.28.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "jest": "^29.7.0",
    "wait-on": "^7.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "forceExit": true
  },
  "build": {
    "appId": "com.edu.devassist",
    "productName": "DevAssist",
    "extends": null,
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSUserNotificationAlertStyle": "alert"
      }
    },
    "extraResources": []
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
