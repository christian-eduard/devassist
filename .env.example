# --- CONFIGURACIÓN DEVASSIST ---

# Nombre del usuario (para personalización de agentes)
USER_NAME=Chris

# Ruta al binario de OpenClaw (opcional, si no está en Homebrew estándar)
# OPENCLAW_PATH=/Users/chris/homebrew/bin/openclaw

# IDs de notificación (para WhatsApp y Telegram)
NOTIFY_TELEGRAM_ID=6541399577
NOTIFY_WHATSAPP_ID=34644984173

# --- BASE DE DATOS NEXUS (POSTGRESQL) ---
DB_HOST=localhost
DB_PORT=54325
DB_USER=devassist_admin
DB_PASSWORD=devassist_secure_pass
DB_NAME=devassist_vault

# --- APIS (Opcional, si no se configuran desde la UI) ---
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
