{
  "name": "devassist",
  "version": "1.0.0",
  "description": "DevAssist — Asistente personal de desarrollo para Mac",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "concurrently \"PORT=3123 BROWSER=none react-scripts start\" \"wait-on http://localhost:3123 && NODE_ENV=development ELECTRON_RUN_AS_NODE= electron .\"",
    "react-build": "react-scripts build",
    "test": "react-scripts test --watchAll=false",
    "build": "npm run react-build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.1.0",
    "@google/genai": "^1.44.0",
    "@google/generative-ai": "^0.24.1",
    "chokidar": "^3.5.3",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "lucide-react": "^0.577.0",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^4.28.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.edu.devassist",
    "productName": "DevAssist",
    "extends": null,
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSUserNotificationAlertStyle": "alert"
      }
    },
    "extraResources": []
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}