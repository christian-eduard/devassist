{
  "name": "devassist",
  "version": "1.0.0",
  "description": "DevAssist — Asistente personal de desarrollo para Mac",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "test": "react-scripts test --watchAll=false",
    "test:unit": "jest tests/fichas-pipeline.test.js --testEnvironment=node --forceExit",
    "test:db": "ELECTRON_RUN_AS_NODE=1 ./node_modules/.bin/electron tests/run-db-tests.js",
    "test:all": "npm run test:unit && npm run test:db",
    "postinstall": "electron-builder install-app-deps",
    "react-build": "vite build"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.4",
    "@google/generative-ai": "^0.24.1",
    "@types/dagre": "^0.7.54",
    "adm-zip": "^0.5.17",
    "axios": "^1.14.0",
    "chokidar": "^3.5.3",
    "dagre": "^0.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "fdir": "^6.5.0",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.14.0",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^4.28.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "vite": "^6.2.6",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^7.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "forceExit": true
  },
  "build": {
    "appId": "com.edu.devassist",
    "productName": "DevAssist",
    "extends": null,
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "NSUserNotificationAlertStyle": "alert"
      }
    },
    "extraResources": []
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  }
}
